{
  "name": "nano-workshop-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack Agentic AI platform for academic workshop data analysis",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --parallel build",
    "lint": "pnpm --parallel lint",
    "test": "pnpm --parallel test",
    "db:up": "docker-compose up -d postgres redis minio",
    "db:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
