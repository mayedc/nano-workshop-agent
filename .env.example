# PostgreSQL
POSTGRES_USER=nwa
POSTGRES_PASSWORD=nwa_secret
POSTGRES_DB=nano_workshop
DATABASE_URL=postgresql+asyncpg://nwa:nwa_secret@localhost:5432/nano_workshop

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nano-workshop

# API
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
